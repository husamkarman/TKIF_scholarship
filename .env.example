INTERNAL_NOTIFICATION_SECRET=change_this_shared_secret
INTERNAL_NOTIFICATION_HMAC_TOLERANCE_SECONDS=300

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_ENCRYPTION=ssl
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_TIMEOUT=10

OTP_ENABLED=true
OTP_LENGTH=6
OTP_TTL_MINUTES=10

MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
