APP_NAME=TKIF Scholarship MVP
APP_ENV=local
APP_URL=http://localhost:8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tkif_scholarship
DB_USER=root
DB_PASS=

SESSION_NAME=tkif_session

N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=replace_me
N8N_WEBHOOK_SUBMIT=/webhook/scholarship-submit

