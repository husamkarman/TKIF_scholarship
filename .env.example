APP_NAME=TKIF Scholarship MVP
APP_ENV=local
APP_URL=http://localhost:8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tkif_scholarship
DB_USER=root
DB_PASS=

SESSION_NAME=tkif_session

REGISTRATION_ENABLED=true
REGISTRATION_DEFAULT_ROLE=student
REGISTRATION_DEFAULT_TENANT_CODE=

EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_METHOD=code
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_TTL_MINUTES=3
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=30
EMAIL_VERIFICATION_REQUIRE_FOR_LOGIN=true

RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_SECONDS=900
RATE_LIMIT_VERIFY_CODE_MAX=10
RATE_LIMIT_VERIFY_CODE_WINDOW_SECONDS=300
RATE_LIMIT_VERIFY_RESEND_MAX=5
RATE_LIMIT_VERIFY_RESEND_WINDOW_SECONDS=600
RATE_LIMIT_OTP_REQUEST_MAX=5
RATE_LIMIT_OTP_REQUEST_WINDOW_SECONDS=900
RATE_LIMIT_OTP_VERIFY_MAX=10
RATE_LIMIT_OTP_VERIFY_WINDOW_SECONDS=300

INTERNAL_NOTIFICATION_ENDPOINT=http://localhost:8080/?page=notification_inbox_receive
INTERNAL_NOTIFICATION_SECRET=change_this_shared_secret
INTERNAL_NOTIFICATION_HMAC_TOLERANCE_SECONDS=300
INTERNAL_NOTIFICATION_WORKER_TOKEN=change_this_worker_token

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_ENCRYPTION=ssl
SMTP_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_TIMEOUT=10

OTP_ENABLED=true
OTP_LENGTH=6
OTP_TTL_MINUTES=10

MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8080/?page=auth_microsoft_callback
MICROSOFT_REDIRECT_URI_LOCAL=http://localhost:8080/?page=auth_microsoft_callback
MICROSOFT_REDIRECT_URI_PROD=https://your-domain/?page=auth_microsoft_callback
MICROSOFT_CLIENT_SECRET=
MICROSOFT_AUTO_PROVISION=true
MICROSOFT_ALLOWED_DOMAIN=
MICROSOFT_DEFAULT_ROLE=student
MICROSOFT_DEFAULT_TENANT_CODE=TKIFMS001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/?page=auth_google_callback
GOOGLE_REDIRECT_URI_LOCAL=http://localhost:8080/?page=auth_google_callback
GOOGLE_REDIRECT_URI_PROD=https://your-domain/?page=auth_google_callback
GOOGLE_AUTO_PROVISION=true
GOOGLE_ALLOWED_DOMAIN=
GOOGLE_DEFAULT_ROLE=student
GOOGLE_DEFAULT_TENANT_CODE=TKIFGO001
