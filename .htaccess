Options -Indexes
RewriteEngine On

# Security headers (safe defaults).
<IfModule mod_headers.c>
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "SAMEORIGIN"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Deny direct access to sensitive project paths when docroot is project root.
RewriteRule ^(app|vendor|sql|scripts|n8n|\.git|\.github)/ - [F,L,NC]
RewriteRule ^(\.env|composer\.(json|lock)|phpunit\.xml)$ - [F,L,NC]

# Canonicalize accidental nested public path.
RewriteRule ^public/public/(.*)$ public/$1 [R=302,L,NC]

# If the domain points at project root, forward requests into public/.
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L,QSA]